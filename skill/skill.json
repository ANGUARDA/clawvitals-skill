{
  "name": "clawvitals",
  "version": "1.2.0",
  "always": false,
  "displayName": "ClawVitals",
  "description": "Check your OpenClaw security vitals. Scans your installation, scores your setup, and shows you exactly what to fix. First scan in seconds.",
  "author": "Anguarda",
  "license": "MIT",
  "homepage": "https://clawvitals.io",
  "repository": "https://github.com/ANGUARDA/clawvitals-skill",
  "minOpenClawVersion": "2026.3.0",
  "controlLibraryVersion": "1.0.0",
  "controlLibraryVersionRange": ">=1.0.0 <2.0.0",
  "permissions": [
    "exec:openclaw:security-audit",
    "exec:openclaw:health",
    "exec:openclaw:update",
    "exec:openclaw:version",
    "filesystem:workspace"
  ],
  "intents": [
    {
      "pattern": [
        "run clawvitals",
        "clawvitals scan",
        "check clawvitals",
        "clawvitals check"
      ],
      "handler": "handleScan"
    },
    {
      "pattern": [
        "show clawvitals details",
        "clawvitals full report",
        "clawvitals details"
      ],
      "handler": "handleDetail"
    }
  ],
  "tags": [
    "security",
    "audit",
    "health-check",
    "openclaw",
    "monitoring"
  ]
}